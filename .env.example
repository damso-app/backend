APP_NAME="Damso API"
ENVIRONMENT="local"
API_V1_PREFIX="/api/v1"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

DATABASE_URL="postgresql+psycopg://postgres.your-project-ref:your-db-password@aws-your-region.pooler.supabase.com:5432/postgres"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
JWT_SECRET="replace-with-jwt-secret"
JWT_SECRET_KEY="replace-with-jwt-secret-key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"
LOGIN_CODE_EXPIRE_MINUTES="5"
OPENAI_API_KEY="replace-with-openai-api-key"
KAKAO_REST_API_KEY="replace-with-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="replace-with-kakao-client-secret"
KAKAO_REDIRECT_URI="http://localhost:8000/api/v1/auth/kakao/callback"
FRONTEND_OAUTH_CALLBACK_URL="http://localhost:3000/oauth/kakao/callback"
GCS_BUCKET_NAME="replace-with-gcs-bucket-name"
GCS_SIGNED_URL_EXPIRE_MINUTES="15"
# GCS 인증은 Application Default Credentials(로컬은 `gcloud auth application-default login`,
# Cloud Run은 런타임 서비스 계정)를 사용한다. 별도 키 파일은 두지 않는다.
# V4 signed URL은 private key가 없는 ID(사용자 ADC, GCE/Cloud Run 메타데이터 자격증명)로는
# 직접 서명할 수 없어 IAM signBlob API로 GCS_SIGNER_SERVICE_ACCOUNT를 impersonate해서 서명한다.
# 로컬: 현재 gcloud 사용자 계정에 이 서비스 계정에 대한 roles/iam.serviceAccountTokenCreator가 필요하다.
# Cloud Run: 런타임 서비스 계정 = 이 값으로 두고, 그 계정에 "자기 자신"에 대한
# roles/iam.serviceAccountTokenCreator를 부여해야 한다.
GCS_SIGNER_SERVICE_ACCOUNT="replace-with-signer-service-account-email"

# 우리 백엔드 자신의 공개 base URL. AI 서버에 넘길 callbackUrl(/api/v1/answers/{answer_id}/ai-callback)을
# 만드는 데 쓴다.
APP_BASE_URL="http://localhost:8000"
# AI 서버 base URL. 비어있으면 AiJobService는 fire-and-forget 호출을 그냥 건너뛴다(주소 미정 상태 대응).
AI_SERVER_BASE_URL=""
AI_JOB_REQUEST_TIMEOUT_SECONDS="5.0"
# AI 서버에 넘기는 signed URL(원본 mediaUrl 조회용 GET, 편집 영상 업로드용 PUT) 만료 시간.
# AI 처리가 큐에서 대기하는 시간까지 커버할 만큼 기본 GCS URL 만료(15분)보다 길게 둔다.
AI_EDITED_VIDEO_UPLOAD_URL_EXPIRE_MINUTES="120"
# callbackToken(콜백 인증용 JWT) 만료 시간. AI 처리 시간을 커버할 만큼 길게 둔다.
AI_CALLBACK_TOKEN_EXPIRE_MINUTES="120"
