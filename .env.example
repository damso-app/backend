APP_NAME="Damso API"
ENVIRONMENT="local"
API_V1_PREFIX="/api/v1"

DATABASE_URL="postgresql+psycopg://postgres.your-project-ref:your-db-password@aws-your-region.pooler.supabase.com:5432/postgres"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
JWT_SECRET="replace-with-jwt-secret"
JWT_SECRET_KEY="replace-with-jwt-secret-key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"
LOGIN_CODE_EXPIRE_MINUTES="5"
OPENAI_API_KEY="replace-with-openai-api-key"
KAKAO_REST_API_KEY="replace-with-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="replace-with-kakao-client-secret"
KAKAO_REDIRECT_URI="http://localhost:8000/api/v1/auth/kakao/callback"
FRONTEND_OAUTH_CALLBACK_URL="http://localhost:3000/oauth/kakao/callback"
